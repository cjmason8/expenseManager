<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn">
    <Appenders>
        <Console name="Console">
            <PatternLayout pattern="%p %c{1} - %m%n" />
        </Console>
    </Appenders>
    <Loggers>
        <Root level="warn" additivity="false">
            <appender-ref ref="Console" />
        </Root>
    </Loggers>
</Configuration>
